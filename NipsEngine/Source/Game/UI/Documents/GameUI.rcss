body {
	width: 100%;
	height: 100%;
	margin: 0px;
	font-family: "NEXON Lv1 Gothic";
	font-weight: bold;
	color: #ffffff;
}

#start-menu, #pause-layer, #ending-panel, #title-intro-layer, #screen-fade-layer {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 100%;
}

#start-menu {
	background-color: rgba(9, 10, 16, 255);
}

#title-intro-layer {
	background-color: rgba(0, 0, 0, 255);
}

#title-intro-icon {
	position: absolute;
	left: 50%;
	top: 50%;
	width: 960px;
	height: auto;
	margin-left: -480px;
	margin-top: -180px;
}

#screen-fade-layer {
	background-color: rgba(0, 0, 0, 0);
}

#title-background {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: auto;
}

#game-title {
	position: absolute;
	left: 0px;
	top: 8%;
	width: 100%;
	height: 24%;
	text-align: center;
}

#title-image {
	width: 66%;
	height: auto;
}

#title-menu {
	position: absolute;
	left: 0px;
	top: 54%;
	width: 100%;
	text-align: center;
}

.title-menu-row {
	display: block;
	width: 100%;
	height: 56px;
	margin-bottom: 10px;
	text-align: center;
}

.title-menu-button {
	display: block;
	width: auto;
	height: 46px;
	margin-left: auto;
	margin-right: auto;
}

.title-menu-button:hover {
	opacity: 0.82;
}

#game-cursor {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 32px;
	height: 32px;
	pointer-events: none;
}

#hud-panel {
	position: absolute;
	left: 30%;
	top: 40px;
	width: 40%;
	height: 28px;
}

#progress-track {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 28px;
	background-color: rgba(26, 26, 26, 210);
	border-width: 1px;
	border-color: rgba(80, 80, 80, 180);
}

#progress-fill {
	position: absolute;
	left: 0px;
	top: 0px;
	height: 28px;
	background-color: rgb(64, 191, 255);
}

#progress-value {
	position: absolute;
	left: 0px;
	top: 5px;
	width: 100%;
	text-align: center;
	font-size: 16px;
	color: #ffffff;
}

#item-status {
	position: absolute;
	right: 36px;
	top: 34px;
	width: 260px;
	padding: 12px;
	background-color: rgba(13, 15, 20, 185);
	border-width: 1px;
	border-color: rgba(110, 130, 150, 150);
}

#current-item-name {
	font-size: 17px;
	color: #ffe08a;
}

#current-item-desc {
	margin-top: 6px;
	font-size: 14px;
	color: #d6d6d6;
}

#crosshair-dot {
	position: absolute;
	left: 50%;
	top: 50%;
	width: 4px;
	height: 4px;
	margin-left: -3px;
	margin-top: -3px;
	background-color: rgba(255, 255, 255, 235);
	border-width: 1px;
	border-color: rgba(82, 82, 82, 190);
	border-radius: 3px;
}

#interaction-hint {
	position: absolute;
	left: 0px;
	bottom: 18%;
	width: 100%;
	text-align: center;
}

.interaction-key {
	display: inline-block;
	position: relative;
	width: 52px;
	height: 48px;
	margin-right: 10px;
	vertical-align: middle;
}

.interaction-key-bg {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 100%;
}

.interaction-key-label {
	position: absolute;
	left: -2px;
	top: 6px;
	width: 100%;
	text-align: center;
	font-size: 28px;
	font-weight: bold;
	color: #17120d;
}

.interaction-hint-text {
	display: inline-block;
	padding: 4px 18px 8px 10px;
	font-size: 28px;
	font-weight: bold;
	color: #f5f0e6;
	font-effect: outline(2px #000000);
	
	position: relative;
	top: 6px;
}

#interaction-secondary-text {
	margin-right: 18px;
}

#item-inspect-panel {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 100%;
	background-color: rgba(0, 0, 0, 145);
}

#item-inspect-content {
	position: absolute;
	left: 50%;
	top: 50%;
	width: 760px;
	height: 360px;
	margin-left: -380px;
	margin-top: -180px;
	background-color: rgba(18, 17, 15, 238);
	border-width: 1px;
	border-color: rgba(230, 205, 150, 180);
}

#item-inspect-image-frame {
	position: absolute;
	left: 28px;
	top: 28px;
	width: 280px;
	height: 304px;
	background-color: rgba(8, 8, 8, 210);
	border-width: 1px;
	border-color: rgba(160, 140, 105, 150);
}

#item-inspect-image {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 100%;
}

#item-inspect-image-placeholder {
	position: absolute;
	left: 50%;
	top: 50%;
	width: 54px;
	height: 54px;
	margin-left: -27px;
	margin-top: -27px;
	background-color: rgba(255, 255, 255, 35);
	border-width: 1px;
	border-color: rgba(255, 255, 255, 90);
}

#item-inspect-text {
	position: absolute;
	left: 340px;
	top: 34px;
	width: 382px;
	height: 292px;
}

#item-inspect-title {
	font-size: 25px;
	font-weight: 900;
	color: #ffe08a;
}

#item-inspect-separator {
	margin-top: 18px;
	width: 100%;
	height: 1px;
	background-color: rgba(230, 205, 150, 150);
}

#item-inspect-desc {
	margin-top: 20px;
	font-size: 18px;
	font-weight: 700;
	line-height: 27px;
	color: #f3ead8;
}

#pause-layer {
	background-color: rgba(0, 0, 0, 150);
}

#pause-panel {
	position: absolute;
	left: 50%;
	top: 50%;
	width: 320px;
	height: 320px;
	margin-left: -160px;
	margin-top: -160px;
	padding: 24px;
	background-color: rgba(20, 20, 22, 245);
	border-width: 1px;
	border-color: rgba(130, 130, 145, 180);
}

#pause-title {
	width: 100%;
	text-align: center;
	font-size: 24px;
	color: #ffffff;
}

.stat-row {
	margin-top: 16px;
	font-size: 16px;
	color: #dcdcdc;
}

.stat-value {
	color: #9bd2ff;
}

.pause-button {
	width: 100%;
	height: 40px;
	margin-top: 16px;
	padding-top: 8px;
	text-align: center;
	font-size: 18px;
	color: #ededed;
	background-color: rgba(38, 40, 45, 255);
	border-width: 1px;
	border-color: rgba(115, 120, 130, 200);
}

.pause-button:hover {
	background-color: rgba(58, 64, 74, 255);
	color: #ffdc64;
}

#dialogue-panel {
	position: absolute;
	left: 10%;
	bottom: 20px;
	width: 80%;
	height: 118px;
	padding: 14px;
	background-color: rgba(15, 15, 20, 220);
	border-width: 1px;
	border-color: rgba(100, 100, 120, 180);
}

#dialogue-speaker {
	font-size: 18px;
	color: #ffd264;
}

#dialogue-text {
	margin-top: 8px;
	font-size: 17px;
	line-height: 22px;
	color: #e6e6e6;
}

#dialogue-hint {
	position: absolute;
	right: 16px;
	bottom: 12px;
	font-size: 14px;
	color: rgba(180, 180, 180, 220);
}

#ending-panel {
	background-color: rgba(8, 8, 12, 230);
}

#the-end {
	position: absolute;
	top: 47%;
	left: 0px;
	width: 100%;
	text-align: center;
	font-size: 44px;
	color: rgba(220, 210, 190, 0);
}
