body {
	width: 100%;
	height: 100%;
	margin: 0px;
	font-family: "NEXON Lv1 Gothic";
	font-weight: bold;
	color: #ffffff;
}

#start-menu, #settings-layer, #credits-layer, #pause-layer, #ending-panel, #title-intro-layer, #screen-fade-layer {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 100%;
}

#start-menu {
	background-color: rgba(9, 10, 16, 255);
}

#title-intro-layer {
	background-color: rgba(0, 0, 0, 255);
}

#title-intro-icon {
	position: absolute;
	left: 50%;
	top: 50%;
	width: 960px;
	height: auto;
	margin-left: -480px;
	margin-top: -180px;
}

#screen-fade-layer {
	background-color: rgba(0, 0, 0, 0);
}

#title-background {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: auto;
}

#game-title {
	position: absolute;
	left: 0px;
	top: 8%;
	width: 100%;
	height: 24%;
	text-align: center;
}

#title-image {
	width: 66%;
	height: auto;
}

#title-menu {
	position: absolute;
	left: 0px;
	top: 54%;
	width: 100%;
	text-align: center;
}

.title-menu-row {
	display: block;
	width: 100%;
	height: 56px;
	margin-bottom: 10px;
	text-align: center;
}

.title-menu-button {
	display: block;
	width: auto;
	height: 46px;
	margin-left: auto;
	margin-right: auto;
}

.title-menu-button:hover {
	opacity: 0.82;
}

#settings-layer {
	background-color: rgba(0, 0, 0, 140);
	z-index: 20;
}

#settings-panel {
	position: absolute;
	left: 50%;
	top: 50%;
	width: 480px;
	height: 326px;
	margin-left: -240px;
	margin-top: -163px;
	background-color: rgba(20, 20, 22, 245);
	border-width: 1px;
	border-color: rgba(130, 130, 145, 180);
}

#settings-title {
	position: absolute;
	left: 0px;
	top: 28px;
	width: 100%;
	text-align: center;
	font-size: 28px;
	color: #ffffff;
}

.settings-row {
	position: absolute;
	left: 44px;
	width: 392px;
	height: 42px;
}

#settings-mouse-row {
	top: 88px;
}

#settings-bgm-row {
	top: 142px;
}

#settings-sfx-row {
	top: 196px;
}

.settings-label {
	position: absolute;
	left: 0px;
	top: 9px;
	width: 204px;
	font-size: 17px;
	color: #dcdcdc;
}

.settings-value {
	position: absolute;
	right: -20px;
	top: 9px;
	width: 58px;
	text-align: right;
	font-size: 17px;
	color: #9bd2ff;
}

.settings-slider {
	display: block;
	position: absolute;
	left: 202px;
	top: 17px;
	width: 132px;
	height: 8px;
	background-color: rgba(38, 40, 45, 255);
	border-width: 1px;
	border-color: rgba(115, 120, 130, 200);
}

.settings-slider-fill {
	display: block;
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 8px;
	background-color: rgb(64, 191, 255);
}

.settings-slider-knob {
	display: block;
	position: absolute;
	left: 100%;
	top: -6px;
	width: 14px;
	height: 20px;
	margin-left: -7px;
	background-color: #ededed;
	border-width: 1px;
	border-color: rgba(40, 44, 52, 255);
}

.settings-slider:hover .settings-slider-knob {
	background-color: #ffdc64;
}

#settings-close-button {
	left: 140px;
	top: 264px;
}

#credits-layer {
	background-color: rgba(0, 0, 0, 140);
	z-index: 20;
}

#credits-panel {
	position: absolute;
	left: 50%;
	top: 50%;
	width: 520px;
	height: 372px;
	margin-left: -260px;
	margin-top: -186px;
	background-color: rgba(20, 20, 22, 245);
	border-width: 1px;
	border-color: rgba(130, 130, 145, 180);
}

#credits-title {
	position: absolute;
	left: 0px;
	top: 28px;
	width: 100%;
	text-align: center;
	font-size: 28px;
	color: #ffffff;
}

.credits-row {
	position: absolute;
	left: 58px;
	width: 480px;
	height: 34px;
	font-size: 18px;
}

#credits-row-1 {
	top: 94px;
}

#credits-row-2 {
	top: 140px;
}

#credits-row-3 {
	top: 186px;
}

#credits-row-4 {
	top: 232px;
}

.credits-name {
	display: inline-block;
	width: 210px;
	font-size: 25px;
	color: #ffe08a;
}

.credits-role {
	display: inline-block;
	width: 200px;
	font-size: 18px;
	color: #dcdcdc;
}

#credits-close-button {
	left: 160px;
	top: 304px;
}

#game-cursor {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 32px;
	height: 32px;
	pointer-events: none;
	z-index: 100;
}

#hud-panel {
	position: absolute;
	left: 30%;
	top: 40px;
	width: 40%;
	height: 28px;
}

#progress-track {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 28px;
	background-color: rgba(26, 26, 26, 210);
	border-width: 1px;
	border-color: rgba(80, 80, 80, 180);
}

#progress-fill {
	position: absolute;
	left: 0px;
	top: 0px;
	height: 28px;
	background-color: rgb(64, 191, 255);
}

#progress-value {
	position: absolute;
	left: 0px;
	top: 5px;
	width: 100%;
	text-align: center;
	font-size: 16px;
	color: #ffffff;
}

#elapsed-time-panel {
	position: absolute;
	left: 34px;
	top: 34px;
	width: 132px;
	height: 52px;
	padding: 8px 12px;
	background-color: rgba(13, 15, 20, 185);
	border-width: 1px;
	border-color: rgba(110, 130, 150, 150);
}

#elapsed-time-label {
	display: block;
	font-size: 13px;
	color: rgba(220, 230, 240, 210);
}

#elapsed-time-value {
	display: block;
	margin-top: 4px;
	font-size: 20px;
	color: #9bd2ff;
}

#item-status {
	position: absolute;
	right: 36px;
	top: 34px;
	width: 260px;
	padding: 12px;
	background-color: rgba(13, 15, 20, 185);
	border-width: 1px;
	border-color: rgba(110, 130, 150, 150);
}

#current-item-name {
	font-size: 17px;
	color: #ffe08a;
}

#current-item-desc {
	margin-top: 6px;
	font-size: 14px;
	color: #d6d6d6;
}

#crosshair-dot {
	position: absolute;
	left: 50%;
	top: 50%;
	width: 4px;
	height: 4px;
	margin-left: -3px;
	margin-top: -3px;
	background-color: rgba(255, 255, 255, 235);
	border-width: 1px;
	border-color: rgba(82, 82, 82, 190);
	border-radius: 3px;
}

#interaction-hint {
	position: absolute;
	left: 0px;
	bottom: 18%;
	width: 100%;
	text-align: center;
}

.interaction-key {
	display: inline-block;
	position: relative;
	width: 52px;
	height: 48px;
	margin-right: 10px;
	vertical-align: middle;
}

.interaction-key-bg {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 100%;
}

.interaction-key-label {
	position: absolute;
	left: -2px;
	top: 6px;
	width: 100%;
	text-align: center;
	font-size: 28px;
	font-weight: bold;
	color: #17120d;
}

.interaction-hint-text {
	display: inline-block;
	padding: 4px 18px 8px 10px;
	font-size: 28px;
	font-weight: bold;
	color: #f5f0e6;
	font-effect: outline(2px #000000);
	
	position: relative;
	top: 6px;
}

#interaction-secondary-text {
	margin-right: 18px;
}

#item-inspect-panel {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 100%;
	background-color: rgba(0, 0, 0, 145);
}

#item-inspect-content {
	position: absolute;
	left: 50%;
	top: 50%;
	width: 760px;
	height: 360px;
	margin-left: -380px;
	margin-top: -180px;
	background-color: rgba(18, 17, 15, 238);
	border-width: 1px;
	border-color: rgba(230, 205, 150, 180);
}

#item-inspect-image-frame {
	position: absolute;
	left: 28px;
	top: 28px;
	width: 280px;
	height: 304px;
	background-color: rgba(8, 8, 8, 210);
	border-width: 1px;
	border-color: rgba(160, 140, 105, 150);
}

#item-inspect-image {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100%;
	height: 100%;
}

#item-inspect-image-placeholder {
	position: absolute;
	left: 50%;
	top: 50%;
	width: 54px;
	height: 54px;
	margin-left: -27px;
	margin-top: -27px;
	background-color: rgba(255, 255, 255, 35);
	border-width: 1px;
	border-color: rgba(255, 255, 255, 90);
}

#item-inspect-text {
	position: absolute;
	left: 340px;
	top: 34px;
	width: 382px;
	height: 292px;
}

#item-inspect-title {
	display: block;
	font-size: 25px;
	font-weight: 900;
	color: #ffe08a;
}

#item-inspect-separator {
	display: block;
	margin-top: 18px;
	width: 100%;
	height: 1px;
	background-color: rgba(230, 205, 150, 150);
}

#item-inspect-desc {
	display: block;
	margin-top: 20px;
	font-size: 18px;
	font-weight: 700;
	line-height: 27px;
	color: #f3ead8;
	white-space: pre-wrap;
}

#pause-layer {
	background-color: rgba(0, 0, 0, 150);
}

#pause-panel {
	position: absolute;
	left: 50%;
	top: 50%;
	width: 360px;
	height: 456px;
	margin-left: -180px;
	margin-top: -228px;
	background-color: rgba(20, 20, 22, 245);
	border-width: 1px;
	border-color: rgba(130, 130, 145, 180);
}

#pause-title {
	position: absolute;
	left: 0px;
	top: 28px;
	width: 100%;
	text-align: center;
	font-size: 28px;
	color: #ffffff;
}

.stat-row {
	position: absolute;
	left: 46px;
	width: 268px;
	height: 24px;
	font-size: 17px;
	color: #dcdcdc;
}

#pause-items-row {
	top: 88px;
}

#pause-time-row {
	top: 122px;
}

#pause-progress-row {
	top: 156px;
}

.stat-value {
	color: #9bd2ff;
}

.pause-button {
	position: absolute;
	left: 80px; 
	width: 200px;
	height: 36px;
	padding-top: 10px;
	text-align: center;
	font-size: 20px; 
	font-weight: bold; 
	color: #ededed;
	background-color: rgba(38, 40, 45, 255);
	border-width: 1px;
	border-color: rgba(115, 120, 130, 200);
}

#retry-button {
	top: 218px;
}

#pause-settings-button {
	top: 276px;
}

#pause-title-button {
	top: 334px;
}

#pause-exit-button {
	top: 392px;
}

.pause-button:hover {
	background-color: rgba(58, 64, 74, 255);
	color: #ffdc64;
}
#dialogue-panel {
	position: absolute;
	left: 10%;
	bottom: 20px;
	width: 80%;
	height: 118px;
	padding: 14px;
	background-color: rgba(15, 15, 20, 220);
	border-width: 1px;
	border-color: rgba(100, 100, 120, 180);
}

#dialogue-speaker {
	display: block;
	font-size: 18px;
	color: #ffd264;
}

#dialogue-text {
	display: block;
	margin-top: 8px;
	font-size: 17px;
	line-height: 22px;
	color: #e6e6e6;
	white-space: pre-wrap;
}

#dialogue-hint {
	position: absolute;
	right: 16px;
	bottom: 12px;
	font-size: 14px;
	color: rgba(180, 180, 180, 220);
}

#ending-panel {
	background-color: rgba(8, 8, 12, 230);
}

#ending-visual-frame {
	position: absolute;
	left: 5%; 
    width: 90%; 
    top: 40px; 
    bottom: 160px;
	margin-left: -380px;
	background-color: rgba(0, 0, 0, 170);
	border-width: 1px;
	border-color: rgba(220, 210, 190, 90);
	overflow: hidden;
}

#ending-visual-image {
	position: absolute;
	left: 0px;
	top: 0px;
	width: 100x;
	height: 100px;
	object-fit: cover;
}

#debug-menu-layer {
	display: none;
	background-color: rgba(0, 0, 0, 160);
	z-index: 50;
}

#debug-menu-panel {
	position: absolute;
	left: 50%;
	top: 50%;
	width: 360px;
	height: 360px;
	margin-left: -180px;
	margin-top: -180px;
	background-color: rgba(30, 10, 10, 245);
	border-width: 2px;
	border-color: rgba(200, 50, 50, 180);
}

#debug-menu-title {
	position: absolute;
	left: 0px;
	top: 24px;
	width: 100%;
	text-align: center;
	font-size: 22px;
	color: #ff8888;
}

#debug-jump-bad { top: 80px; }
#debug-jump-normal { top: 138px; }
#debug-jump-good { top: 196px; }
#debug-menu-close { top: 274px; }

#the-end {
	position: absolute;
	top: 40%;
	left: 0px;
	width: 100%;
	text-align: center;
	font-size: 44px;
	color: rgba(220, 210, 190, 0);
}

#ending-buttons {
	display: none;
	position: absolute;
	top: 55%;
	left: 0px;
	width: 100%;
	text-align: center;
}

#save-score-button, #exit-to-main-button {
	display: inline-block;
	position: static;
	margin: 0px 10px;
}
